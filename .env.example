# --- Vexa Environment template ---
# Copy to the repo root as .env, then fill the THREE secrets marked REPLACE_ME:
#   cp .env.example .env
#
# This file is a COMMITTED template — never put real secrets here. The real .env
# is gitignored. Non-secret identifiers (CF account/database IDs) are pre-filled
# for convenience; the actual tokens/keys are left blank.

# ============================================================================
# Transcription — Groq -> Deepgram provider service (no Vexa, no token)
# ============================================================================
# Points at services/transcription-service running in cloud-provider mode
# (docker-compose.providers.yml), which is aliased as `transcription-service`
# on vexa-network. The bot needs no token unless that service sets its own.
# NOTE: your GROQ_API_KEY / DEEPGRAM_API_KEY do NOT go here — put them in
#       services/transcription-service/.env before launching that service.
# The token is set to `ci-placeholder` so `make all` preflight skips the
# Vexa-hosted token check (we're not using Vexa). The provider service ignores
# this value unless it sets its own API_TOKEN.
TRANSCRIPTION_SERVICE_URL=http://transcription-service:8000
TRANSCRIPTION_SERVICE_TOKEN=ci-placeholder

# ============================================================================
# Ports — change these to avoid conflicts with other stacks
# ============================================================================
API_GATEWAY_HOST_PORT=8056
ADMIN_API_PORT=8057
RUNTIME_API_PORT=8090
AGENT_API_PORT=8100
CALENDAR_SERVICE_PORT=8050
DASHBOARD_HOST_PORT=3001
POSTGRES_HOST_PORT=5458
MCP_HOST_PORT=18888
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# ============================================================================
# Defaults — work as-is for local dev
# ============================================================================
ADMIN_TOKEN=changeme
IMAGE_TAG=latest
BROWSER_IMAGE=vexaai/vexa-bot:latest

# Bot display name shown in meetings (override anytime)
DEFAULT_BOT_NAME=Munshot Notetaker

# Database (embedded postgres by default)
DB_NAME=vexa
DB_USER=postgres
DB_PASSWORD=postgres

# Storage (embedded minio by default)
STORAGE_BACKEND=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vexa-access-key
MINIO_SECRET_KEY=vexa-secret-key
MINIO_BUCKET=vexa
MINIO_SECURE=false

# Agent API — Claude credentials (optional)
CLAUDE_CREDENTIALS_PATH=
CLAUDE_JSON_PATH=

# ============================================================================
# Multi-user auth & per-user transcript isolation
# ============================================================================
# The platform is multi-tenant at the DB layer: every meeting/transcript is
# owned by a user_id and reads are filtered by the caller's identity. These
# knobs turn that isolation ON for a hosted, multi-user deployment.
#
# VEXA_REQUIRE_AUTH: when true, the dashboard requires a logged-in user for all
#   data access — there is NO shared-key fallback, so an unauthenticated visitor
#   can't act as the shared system user and see its data. Leave false/unset for
#   local/dev single-tenant use. Set true in production.
VEXA_REQUIRE_AUTH=false
#
# Google OAuth SSO (NextAuth). Set all three to enable "Sign in with Google".
# Redirect URI: https://<your-dashboard-host>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
#
# DEFAULT_MAX_CONCURRENT_BOTS: per-user concurrent-bot limit assigned to a NEW
#   user at signup (admin-api). Prevents a fresh account from being unlimited.
DEFAULT_MAX_CONCURRENT_BOTS=2
#
# GLOBAL_MAX_CONCURRENT_BOTS: hard ceiling on total active bots across ALL users
#   (meeting-api) — protects a fixed-capacity host (e.g. a single EC2 sized for
#   ~7 bots). 0 = disabled (no global cap). Set to your host's bot capacity.
GLOBAL_MAX_CONCURRENT_BOTS=0

# ============================================================================
# Calendar auto-join + no-knock notetaker (Task C)
# ============================================================================
# Calendar auto-dispatch: the calendar-service polls connected users' Google
# Calendars and launches a bot ~lead-time before each meeting.
CALENDAR_SYNC_INTERVAL_SECONDS=300
CALENDAR_LEAD_TIME_MINUTES=2
# BOT_API_TOKEN: legacy fallback token for calendar dispatch; ownership is now
# set per-user via injected identity, so this can stay blank.
BOT_API_TOKEN=
#
# NO-KNOCK: shared notetaker Google session. Seed it ONCE (log the notetaker
# Gmail in via a browser_session bot — see services/calendar-service/README or
# AWS_BUILD_PLAN.txt), then set this to that session's S3 path. Once set, EVERY
# bot joins signed-in as the notetaker → admitted without a knock on consumer /
# same-org meetings. Leave blank to keep bots anonymous (they will knock).
NOTETAKER_S3_PATH=

# ============================================================================
# Cloudflare D1 transcript mirror (ACTIVE)
# ============================================================================
# account/database IDs are non-secret identifiers (pre-filled).
# CF_API_TOKEN is the only D1 secret — create one in the Cloudflare dashboard
# (My Profile -> API Tokens -> Custom -> Account / D1 / Edit) and paste below.
CLOUDFLARE_D1_ENABLED=true
CF_ACCOUNT_ID=489675fbe898cd94904c654de83ade00
CF_D1_DATABASE_ID=d43cc292-3389-42ba-bd20-184ac4335360
CF_API_TOKEN=REPLACE_ME_D1_API_TOKEN
CF_D1_TABLE=transcriptions
